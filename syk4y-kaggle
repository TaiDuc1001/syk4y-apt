#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  syk4y kaggle [--repo-root DIR] <subcommand> [options]

Subcommands:
  login    Configure Kaggle credentials (~/.kaggle/kaggle.json)
  upload   Upload changed artifacts to Kaggle (same behavior as old 'syk4y upload')

Examples:
  syk4y kaggle login
  syk4y kaggle upload --force
USAGE
}

login_usage() {
  cat <<'USAGE'
Usage:
  syk4y kaggle login [--username USERNAME] [--key KEY] [--force] [--non-interactive]

Options:
  --username USERNAME   Kaggle username
  --key KEY             Kaggle API key
  --force               Overwrite existing ~/.kaggle/kaggle.json
  --non-interactive     Fail instead of prompting for missing values
  -h, --help            Show this help

If --username/--key are omitted, values are taken from:
  1) KAGGLE_USERNAME / KAGGLE_KEY env vars
  2) existing ~/.kaggle/kaggle.json (status only)
  3) interactive prompt
USAGE
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: $cmd is required." >&2
    exit 1
  fi
}

kaggle_login() {
  require_cmd python3

  local username="${KAGGLE_USERNAME:-}"
  local key="${KAGGLE_KEY:-}"
  local force=0
  local non_interactive=0
  local kaggle_dir="$HOME/.kaggle"
  local kaggle_json="$kaggle_dir/kaggle.json"
  local has_explicit_creds=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --username)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for $1" >&2
          exit 2
        fi
        username="$2"
        shift 2
        ;;
      --key)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for $1" >&2
          exit 2
        fi
        key="$2"
        shift 2
        ;;
      --force)
        force=1
        shift
        ;;
      --non-interactive)
        non_interactive=1
        shift
        ;;
      -h|--help)
        login_usage
        exit 0
        ;;
      *)
        echo "Unknown login option: $1" >&2
        login_usage >&2
        exit 2
        ;;
    esac
  done

  if [[ -n "$username" || -n "$key" ]]; then
    has_explicit_creds=1
  fi

  if [[ "$force" -eq 0 ]] && [[ "$has_explicit_creds" -eq 0 ]] && [[ -f "$kaggle_json" ]]; then
    local existing_status existing_username parse_out
    parse_out="$(
      python3 - "$kaggle_json" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("INVALID\t")
    raise SystemExit(0)

username = data.get("username")
key = data.get("key")
if isinstance(username, str) and username.strip() and isinstance(key, str) and key.strip():
    print(f"OK\t{username.strip()}")
else:
    print("INVALID\t")
PY
    )"
    existing_status="${parse_out%%$'\t'*}"
    existing_username="${parse_out#*$'\t'}"

    if [[ "$existing_status" == "OK" ]]; then
      echo "Kaggle credentials already configured."
      echo "  file: $kaggle_json"
      echo "  username: $existing_username"
      if command -v kaggle >/dev/null 2>&1; then
        if kaggle datasets list -s test -p 1 >/dev/null 2>&1; then
          echo "  auth check: OK"
        else
          echo "  auth check: failed (username/key may be invalid)."
        fi
      else
        echo "  auth check: skipped (kaggle CLI not found)"
      fi
      echo "Use --force or pass --username/--key to overwrite credentials."
      return 0
    fi

    echo "Existing $kaggle_json is invalid. Reconfiguring..."
  fi

  if [[ -z "$username" ]] || [[ -z "$key" ]]; then
    if [[ "$non_interactive" -eq 1 ]]; then
      echo "Error: missing Kaggle credentials. Provide --username/--key or KAGGLE_USERNAME/KAGGLE_KEY." >&2
      exit 1
    fi

    if [[ -z "$username" ]]; then
      read -r -p "Kaggle username: " username
    fi
    if [[ -z "$key" ]]; then
      read -r -s -p "Kaggle API key: " key
      echo
    fi
  fi

  if [[ -z "$username" ]] || [[ -z "$key" ]]; then
    echo "Error: username/key cannot be empty." >&2
    exit 1
  fi

  mkdir -p "$kaggle_dir"
  chmod 700 "$kaggle_dir"

  python3 - "$kaggle_json" "$username" "$key" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
username = sys.argv[2]
key = sys.argv[3]
path.write_text(json.dumps({"username": username, "key": key}, indent=2) + "\n", encoding="utf-8")
PY

  chmod 600 "$kaggle_json"

  # Best-effort auth check if kaggle CLI is available.
  if command -v kaggle >/dev/null 2>&1; then
    if kaggle datasets list -s test -p 1 >/dev/null 2>&1; then
      echo "Kaggle credentials saved and verified: $kaggle_json"
    else
      echo "Kaggle credentials saved at $kaggle_json (verification command failed)." >&2
      echo "Check username/key and try: kaggle datasets list -s test -p 1" >&2
    fi
  else
    echo "Kaggle credentials saved at $kaggle_json"
    echo "Install kaggle CLI to verify: kaggle datasets list -s test -p 1"
  fi
}

main() {
  local repo_root
  repo_root="$(pwd)"

  if [[ $# -gt 0 ]] && [[ "$1" == "--repo-root" ]]; then
    if [[ $# -lt 2 ]]; then
      echo "Missing value for --repo-root" >&2
      exit 2
    fi
    repo_root="$2"
    shift 2
  fi

  if [[ $# -eq 0 ]]; then
    usage >&2
    exit 2
  fi

  local subcommand="$1"
  shift

  case "$subcommand" in
    login)
      kaggle_login "$@"
      ;;
    upload)
      exec "$SCRIPT_DIR/syk4y-upload" --repo-root "$repo_root" "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown kaggle subcommand: $subcommand" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
