#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/syk4y-cli-lib/python_env.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/syk4y-cli-lib/kaggle_env.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/syk4y-cli-lib/string_utils.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/syk4y-cli-lib/kaggle_login.sh"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/syk4y-cli-lib/kaggle_upload.sh"

usage() {
  cat "$SCRIPT_DIR/templates/kaggle-main-usage.txt"
}

main() {
  local repo_root
  repo_root="$(pwd)"

  if [[ $# -gt 0 ]] && [[ "$1" == "--repo-root" ]]; then
    if [[ $# -lt 2 ]]; then
      echo "Missing value for --repo-root" >&2
      exit 2
    fi
    repo_root="$2"
    shift 2
  fi

  PYTHON_BIN="$(syk4y_resolve_python_bin_or_die "$repo_root" "syk4y")"

  if [[ $# -eq 0 ]]; then
    usage >&2
    exit 2
  fi

  local subcommand="$1"
  shift

  case "$subcommand" in
    login)
      kaggle_login "$@"
      ;;
    upload)
      kaggle_upload --repo-root "$repo_root" "$@"
      ;;
    account)
      exec "$PYTHON_BIN" "$SCRIPT_DIR/syk4y-lib/account_cli.py" "$@"
      ;;
    run)
      exec "$PYTHON_BIN" "$SCRIPT_DIR/syk4y-lib/run_cli.py" "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown kaggle subcommand: $subcommand" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
