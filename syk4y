#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat "$SCRIPT_DIR/templates/syk4y-main-usage.txt"
}

repo_root="$(pwd)"
if [[ $# -gt 0 ]]; then
  case "$1" in
    --repo-root)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --repo-root" >&2
        exit 2
      fi
      repo_root="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 2
fi

command="$1"
shift

if [[ ! -d "$repo_root" ]]; then
  echo "Error: invalid --repo-root directory: $repo_root" >&2
  exit 1
fi

case "$command" in
  init)
    exec "$SCRIPT_DIR/syk4y-init" --repo-root "$repo_root" "$@"
    ;;
  gen)
    exec "$SCRIPT_DIR/syk4y-gen" --repo-root "$repo_root" "$@"
    ;;
  kaggle)
    exec "$SCRIPT_DIR/syk4y-kaggle" --repo-root "$repo_root" "$@"
    ;;
  doctor)
    exec "$SCRIPT_DIR/syk4y-doctor" --repo-root "$repo_root" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
