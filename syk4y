#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
syk4y - Kaggle artifact automation tool

Usage:
  syk4y [--repo-root DIR] <command> [command options]

Commands:
  init         Setup Kaggle upload folders/metadata for selected artifacts (no git required)
  gen          Generate gen-full-repo.py (initialize upload folders only with -a/--artifact)
  kaggle       Kaggle helpers (login/upload)
  doctor       Check environment and repository readiness
  help         Show this help

Global options:
  --repo-root DIR   Target repository root (default: current directory)
  -h, --help        Show this help
USAGE
}

repo_root="$(pwd)"
if [[ $# -gt 0 ]]; then
  case "$1" in
    --repo-root)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --repo-root" >&2
        exit 2
      fi
      repo_root="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac
fi

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 2
fi

command="$1"
shift

if [[ ! -d "$repo_root" ]]; then
  echo "Error: invalid --repo-root directory: $repo_root" >&2
  exit 1
fi

case "$command" in
  init)
    exec "$SCRIPT_DIR/syk4y-init" --repo-root "$repo_root" "$@"
    ;;
  gen)
    exec "$SCRIPT_DIR/syk4y-gen" --repo-root "$repo_root" "$@"
    ;;
  kaggle)
    exec "$SCRIPT_DIR/syk4y-kaggle" --repo-root "$repo_root" "$@"
    ;;
  doctor)
    exec "$SCRIPT_DIR/syk4y-doctor" --repo-root "$repo_root" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
