#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat "$SCRIPT_DIR/templates/syk4y-init-usage.txt"
}

repo_root="$(pwd)"
if [[ $# -gt 0 ]] && [[ "$1" == "--repo-root" ]]; then
  if [[ $# -lt 2 ]]; then
    echo "Missing value for --repo-root" >&2
    exit 2
  fi
  repo_root="$2"
  shift 2
fi

args=(--repo-root "$repo_root" --skip-gen)
artifacts=()

if ! repo_root_abs="$(cd "$repo_root" 2>/dev/null && pwd)"; then
  echo "Error: invalid --repo-root '$repo_root'." >&2
  exit 2
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    -u|--upload-dir|-w|--wheelhouse)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        artifacts+=("$1")
        shift
      done
      ;;
    -* )
      echo "Unknown init option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      artifacts+=("$1")
      shift
      ;;
  esac
done

if [[ "${#artifacts[@]}" -eq 0 ]]; then
  echo "Error: init requires at least one artifact." >&2
  usage >&2
  exit 2
fi

for artifact in "${artifacts[@]}"; do
  artifact_path=""
  if [[ -z "$artifact" ]]; then
    echo "Error: artifact name cannot be empty." >&2
    exit 2
  fi
  if [[ "$artifact" != "wheelhouse" ]]; then
    if [[ "$artifact" == /* ]]; then
      artifact_path="$artifact"
    else
      artifact_path="$repo_root_abs/$artifact"
    fi
    if [[ ! -e "$artifact_path" && ! -L "$artifact_path" ]]; then
      echo "Error: artifact '$artifact' does not exist (resolved: $artifact_path)." >&2
      exit 2
    fi
    if [[ ! -f "$artifact_path" && ! -d "$artifact_path" && ! -L "$artifact_path" ]]; then
      echo "Error: artifact '$artifact' must be a file, directory, or symlink (resolved: $artifact_path)." >&2
      exit 2
    fi
  fi
  args+=(--artifact "$artifact")
done

exec "$SCRIPT_DIR/syk4y-gen" "${args[@]}"
