#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  syk4y build-wheel [--repo-root DIR] [options]

Options:
  -u, --upload-dir DIR         Upload root (default: kaggle_upload under repo root)
  --python-bin BIN             Python interpreter for helper actions
  --wheelhouse-python BIN      Python interpreter used to resolve/build wheels
  --jobs N                     Parallel wheel build jobs
  -h, --help                   Show this help
USAGE
}

repo_root="$(pwd)"
if [[ $# -gt 0 ]] && [[ "$1" == "--repo-root" ]]; then
  if [[ $# -lt 2 ]]; then
    echo "Missing value for --repo-root" >&2
    exit 2
  fi
  repo_root="$2"
  shift 2
fi

upload_root=""
python_bin=""
wheelhouse_python=""
jobs=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -u|--upload-dir)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      upload_root="$2"
      shift 2
      ;;
    --python-bin)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      python_bin="$2"
      shift 2
      ;;
    --wheelhouse-python)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      wheelhouse_python="$2"
      shift 2
      ;;
    --jobs)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      jobs="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown build-wheel option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

env_args=()
if [[ -n "$upload_root" ]]; then
  env_args+=(KAGGLE_UPLOAD_ROOT="$upload_root")
fi
if [[ -n "$python_bin" ]]; then
  env_args+=(PYTHON_BIN="$python_bin")
fi
if [[ -n "$wheelhouse_python" ]]; then
  env_args+=(WHEELHOUSE_PYTHON="$wheelhouse_python")
fi
if [[ -n "$jobs" ]]; then
  env_args+=(WHEEL_JOBS="$jobs")
fi

exec env "${env_args[@]}" "$SCRIPT_DIR/syk4y-upload-artifacts" --repo-root "$repo_root" --build-wheel-only
