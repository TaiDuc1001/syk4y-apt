#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

OUT_FILE=""
OUT_FILE_EXPLICIT=0
WHEELHOUSE_FILE="wheelhouse.zip"
UPLOAD_ROOT="kaggle_upload"
REPO_ROOT_OVERRIDE=""
SKIP_GEN=0
SELECTED_ARTIFACTS=()

usage() {
  cat <<'USAGE'
Generate repo snapshot script; optionally initialize split Kaggle upload artifact folders.

Usage:
  syk4y gen [options]

Options:
  --repo-root DIR        Target repository root (default: git root, or CWD with --skip-gen)
  --skip-gen             Skip generating gen-full.py and only setup Kaggle upload folders
  -a, --artifact NAME    Artifact to initialize (repeatable).
                         Any artifact path is allowed.
                         Special case: 'wheelhouse' triggers wheelhouse build flow.
                         Default: none (no upload-folder initialization).
  -o, --out FILE         Output snapshot script path (default: <upload-dir>/gen-full.py)
  -w, --wheelhouse FILE  Wheelhouse archive name/path (default: wheelhouse.zip in upload dataset folder)
  -u, --upload-dir DIR   Kaggle upload root directory (default: kaggle_upload)
  -h, --help             Show this help
USAGE
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: $cmd is required." >&2
    exit 1
  fi
}

slugify() {
  local value="$1"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  value="$(printf '%s' "$value" | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  if [[ -z "$value" ]]; then
    value="dataset-artifacts"
  fi
  printf '%s\n' "$value"
}

resolve_kaggle_username() {
  local strict_mode="${SYK4Y_REQUIRE_KAGGLE_USERNAME:-0}"
  if [[ -n "${KAGGLE_USERNAME:-}" ]]; then
    printf '%s\n' "$KAGGLE_USERNAME"
    return
  fi

  local detected=""
  detected="$("$PYTHON_BIN" - <<'PY'
import json
from pathlib import Path

cfg = Path.home() / '.kaggle' / 'kaggle.json'
if cfg.exists():
    try:
        data = json.loads(cfg.read_text(encoding='utf-8'))
        user = data.get('username')
        if isinstance(user, str) and user.strip():
            print(user.strip())
    except Exception:
        pass
PY
)"

  if [[ -n "$detected" ]]; then
    printf '%s\n' "$detected"
    return
  fi

  if [[ "$strict_mode" == "1" ]]; then
    echo "Error: could not resolve Kaggle username. Set KAGGLE_USERNAME or ~/.kaggle/kaggle.json." >&2
    exit 1
  fi

  echo "Warning: Kaggle username not found. Using placeholder 'your-kaggle-username'." >&2
  echo "Set KAGGLE_USERNAME (or run 'syk4y kaggle login') to generate real dataset ids." >&2
  printf '%s\n' "your-kaggle-username"
}

print_python_install_hint() {
  cat >&2 <<'HINT'
No usable Python interpreter was found.
Install one of:
  - Ubuntu/Debian: sudo apt update && sudo apt install -y python3 python3-venv
  - Or create local venv: uv venv .venv
HINT
}

is_python_bin_usable() {
  local py="$1"
  if [[ -z "$py" ]]; then
    return 1
  fi
  if [[ "$py" == */* ]]; then
    [[ -x "$py" ]]
    return
  fi
  command -v "$py" >/dev/null 2>&1
}

find_repo_venv_python() {
  local repo_root="$1"
  local candidate dir_name dir_lc
  local -a preferred=(.venv venv .env env)

  for dir_name in "${preferred[@]}"; do
    candidate="$repo_root/$dir_name/bin/python"
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  while IFS= read -r dir_name; do
    dir_lc="${dir_name,,}"
    if [[ "$dir_lc" != *venv* ]] && [[ "$dir_lc" != "env" ]] && [[ "$dir_lc" != ".env" ]] && [[ "$dir_lc" != env-* ]] && [[ "$dir_lc" != .env-* ]] && [[ "$dir_lc" != *-env ]]; then
      continue
    fi
    candidate="$repo_root/$dir_name/bin/python"
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done < <(find "$repo_root" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | LC_ALL=C sort -u)

  return 1
}

resolve_python_bin() {
  local repo_root="$1"
  local python_bin="${PYTHON_BIN:-}"
  local detected=""

  if [[ -n "$python_bin" ]]; then
    if is_python_bin_usable "$python_bin"; then
      printf '%s\n' "$python_bin"
      return 0
    fi
    echo "Error: PYTHON_BIN points to unusable interpreter: $python_bin" >&2
    exit 1
  fi

  detected="$(find_repo_venv_python "$repo_root" || true)"
  if [[ -n "$detected" ]]; then
    printf '%s\n' "$detected"
    return 0
  fi

  if command -v uv >/dev/null 2>&1; then
    detected="$(uv --directory "$repo_root" python find 2>/dev/null || true)"
    if is_python_bin_usable "$detected"; then
      printf '%s\n' "$detected"
      return 0
    fi
  fi

  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "python3"
    return 0
  fi
  if command -v python >/dev/null 2>&1; then
    printf '%s\n' "python"
    return 0
  fi

  echo "Error: Python is required for syk4y gen." >&2
  print_python_install_hint
  exit 1
}

build_wheelhouse_for_init() {
  local tmp_root tmp_upload_root tmp_wheelhouse_path
  tmp_root="${SYK4Y_WHEELHOUSE_TMP_ROOT:-/tmp/syk4y-wheelhouse-cache}"
  tmp_upload_root="$tmp_root/$REPO_SLUG"
  tmp_wheelhouse_path="$tmp_upload_root/${REPO_SLUG}-wheelhouse/wheelhouse.zip"

  mkdir -p "$tmp_upload_root"
  mkdir -p "$(dirname "$WHEELHOUSE_ABS")"

  echo "    wheelhouse build root: $tmp_upload_root"
  "$SCRIPT_DIR/syk4y-kaggle" --repo-root "$REPO_ROOT" upload --upload-dir "$tmp_upload_root" --build-wheel-only

  if [[ ! -f "$tmp_wheelhouse_path" ]]; then
    echo "Error: wheelhouse build finished but missing '$tmp_wheelhouse_path'." >&2
    exit 1
  fi

  ln -sfn "$tmp_wheelhouse_path" "$WHEELHOUSE_ABS"
  echo "    wheelhouse source: $tmp_wheelhouse_path"
  echo "    link: $WHEELHOUSE_ABS -> $tmp_wheelhouse_path"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo-root)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      REPO_ROOT_OVERRIDE="$2"
      shift 2
      ;;
    --skip-gen)
      SKIP_GEN=1
      shift
      ;;
    -a|--artifact)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      SELECTED_ARTIFACTS+=("$2")
      shift 2
      ;;
    -o|--out)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      OUT_FILE="$2"
      OUT_FILE_EXPLICIT=1
      shift 2
      ;;
    -w|--wheelhouse)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      WHEELHOUSE_FILE="$2"
      shift 2
      ;;
    -u|--upload-dir)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      UPLOAD_ROOT="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$OUT_FILE_EXPLICIT" -eq 0 ]]; then
  OUT_FILE="${UPLOAD_ROOT}/gen-full.py"
fi

if [[ "${#SELECTED_ARTIFACTS[@]}" -gt 0 ]]; then
  declare -A seen_artifacts=()
  declare -A artifact_slug_owner=()
  normalized_artifacts=()
  for artifact in "${SELECTED_ARTIFACTS[@]}"; do
    if [[ -z "$artifact" ]]; then
      echo "Error: artifact name cannot be empty." >&2
      exit 2
    fi
    if [[ -z "${seen_artifacts[$artifact]+x}" ]]; then
      artifact_slug="$(slugify "$artifact")"
      if [[ -n "${artifact_slug_owner[$artifact_slug]+x}" ]] && [[ "${artifact_slug_owner[$artifact_slug]}" != "$artifact" ]]; then
        echo "Error: artifact slug collision between '${artifact_slug_owner[$artifact_slug]}' and '$artifact' (slug: '$artifact_slug')." >&2
        echo "Use distinct artifact names that slugify uniquely." >&2
        exit 2
      fi
      seen_artifacts["$artifact"]=1
      artifact_slug_owner["$artifact_slug"]="$artifact"
      normalized_artifacts+=("$artifact")
    fi
  done
  SELECTED_ARTIFACTS=("${normalized_artifacts[@]}")
fi

if [[ -n "$REPO_ROOT_OVERRIDE" ]]; then
  if [[ "$REPO_ROOT_OVERRIDE" == /* ]]; then
    REPO_ROOT="$REPO_ROOT_OVERRIDE"
  else
    REPO_ROOT="$(cd "$REPO_ROOT_OVERRIDE" && pwd)"
  fi
else
  if [[ "$SKIP_GEN" -eq 1 ]]; then
    REPO_ROOT="$(pwd)"
  else
    require_cmd git
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  fi
fi

if [[ -z "$REPO_ROOT" ]] || [[ ! -d "$REPO_ROOT" ]]; then
  echo "Error: invalid repository root: '$REPO_ROOT'." >&2
  exit 1
fi

if [[ "$SKIP_GEN" -eq 0 ]]; then
  require_cmd git
  GIT_ROOT="$(git -C "$REPO_ROOT" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -z "$GIT_ROOT" ]]; then
    echo "Error: 'gen' requires a git repository. '$REPO_ROOT' is not inside a git work tree." >&2
    echo "Hint: run inside a git repo, or use --skip-gen for setup-only mode." >&2
    exit 1
  fi
  REPO_ROOT="$GIT_ROOT"
fi

if [[ "$SKIP_GEN" -eq 1 ]] && [[ "${#SELECTED_ARTIFACTS[@]}" -eq 0 ]]; then
  echo "Error: nothing to do. Use -a/--artifact to initialize upload artifact folders, or run without --skip-gen to generate snapshot script." >&2
  exit 2
fi

cd "$REPO_ROOT"

REPO_NAME="$(basename "$REPO_ROOT")"
REPO_SLUG="$(slugify "$REPO_NAME")"
PYTHON_BIN="$(resolve_python_bin "$REPO_ROOT")"
KAGGLE_USERNAME=""
if [[ "${#SELECTED_ARTIFACTS[@]}" -gt 0 ]]; then
  KAGGLE_USERNAME="$(resolve_kaggle_username)"
fi

if [[ "$OUT_FILE" == /* ]]; then
  OUT_ABS="$OUT_FILE"
else
  OUT_ABS="$REPO_ROOT/$OUT_FILE"
fi

if [[ "${#SELECTED_ARTIFACTS[@]}" -gt 0 ]]; then
  if [[ "$UPLOAD_ROOT" == /* ]]; then
    UPLOAD_ROOT_ABS="$UPLOAD_ROOT"
  else
    UPLOAD_ROOT_ABS="$REPO_ROOT/$UPLOAD_ROOT"
  fi

  WHEELHOUSE_DATASET_DIR="$UPLOAD_ROOT_ABS/${REPO_SLUG}-wheelhouse"

  if [[ "$WHEELHOUSE_FILE" == /* ]]; then
    WHEELHOUSE_ABS="$WHEELHOUSE_FILE"
  else
    WHEELHOUSE_ABS="$WHEELHOUSE_DATASET_DIR/$WHEELHOUSE_FILE"
  fi
fi

if [[ "$SKIP_GEN" -eq 0 ]]; then
  "$PYTHON_BIN" - "$REPO_ROOT" "$OUT_ABS" <<'PY'
import base64
import hashlib
import io
import json
import lzma
import os
import stat
import subprocess
import sys
import tarfile
import tempfile
from pathlib import Path

FORMAT_VERSION = 2
MANIFEST_VERSION = 1
PAYLOAD_CODEC = "lzma/xz"
CODEC = {"name": PAYLOAD_CODEC, "dictionary": None}

CHUNK_FILE_MIN_BYTES = 4096
CHUNK_MIN_BYTES = 2048
CHUNK_TARGET_BITS = 13  # ~8KiB average
CHUNK_MAX_BYTES = 16384
CHUNK_BOUNDARY_MASK = (1 << CHUNK_TARGET_BITS) - 1

repo_root = Path(sys.argv[1]).resolve(strict=False)
out_abs = Path(sys.argv[2]).resolve(strict=False)

out_abs.parent.mkdir(parents=True, exist_ok=True)

out_skip = None
try:
    out_skip = out_abs.relative_to(repo_root).as_posix()
except ValueError:
    out_skip = None


def _encode_text_b64(value: str) -> str:
    return base64.b64encode(value.encode("utf-8", "surrogateescape")).decode("ascii")


def _stable_tarinfo(name: str, mode: int, size: int = 0, *, typeflag: bytes = tarfile.REGTYPE, linkname: str = "") -> tarfile.TarInfo:
    info = tarfile.TarInfo(name=name)
    info.mode = mode
    info.mtime = 0
    info.uid = 0
    info.gid = 0
    info.uname = ""
    info.gname = ""
    info.type = typeflag
    info.size = size
    if typeflag == tarfile.SYMTYPE:
        info.linkname = linkname
    return info


def _build_tar_bundle(entries) -> bytes:
    out = io.BytesIO()
    with tarfile.open(fileobj=out, mode="w") as tf:
        for entry in entries:
            rel_path = entry["path"]
            kind = entry["kind"]
            if kind == "symlink":
                info = _stable_tarinfo(rel_path, 0o777, 0, typeflag=tarfile.SYMTYPE, linkname=entry["target"])
                tf.addfile(info)
                continue

            data = entry["data"]
            info = _stable_tarinfo(rel_path, entry["mode"], len(data))
            tf.addfile(info, io.BytesIO(data))
    return out.getvalue()


def _chunk_content_defined(data: bytes):
    if len(data) <= CHUNK_MIN_BYTES:
        return [data]

    chunks = []
    start = 0
    rolling = 0

    for idx, byte in enumerate(data):
        rolling = ((rolling << 5) ^ (rolling >> 2) ^ byte) & 0xFFFFFFFF
        cur_size = idx - start + 1
        if cur_size < CHUNK_MIN_BYTES:
            continue
        if (rolling & CHUNK_BOUNDARY_MASK) == 0 or cur_size >= CHUNK_MAX_BYTES:
            chunks.append(data[start : idx + 1])
            start = idx + 1
            rolling = 0

    if start < len(data):
        chunks.append(data[start:])

    return chunks if chunks else [data]


def _build_chunkstore_bundle(entries) -> bytes:
    blobs = {}
    manifest_entries = []

    for entry in entries:
        rel_path = entry["path"]
        path_b64 = _encode_text_b64(rel_path)
        kind = entry["kind"]

        if kind == "symlink":
            manifest_entries.append(
                {
                    "kind": "symlink",
                    "path_b64": path_b64,
                    "target_b64": _encode_text_b64(entry["target"]),
                }
            )
            continue

        mode = entry["mode"]
        data = entry["data"]
        if len(data) < CHUNK_FILE_MIN_BYTES:
            digest = hashlib.sha256(data).hexdigest()
            blobs.setdefault(digest, data)
            manifest_entries.append(
                {"kind": "file", "path_b64": path_b64, "mode": mode, "blob": digest}
            )
            continue

        chunks = _chunk_content_defined(data)
        chunk_ids = []
        for chunk in chunks:
            digest = hashlib.sha256(chunk).hexdigest()
            blobs.setdefault(digest, chunk)
            chunk_ids.append(digest)

        if len(chunk_ids) <= 1:
            manifest_entries.append(
                {"kind": "file", "path_b64": path_b64, "mode": mode, "blob": chunk_ids[0]}
            )
        else:
            manifest_entries.append(
                {
                    "kind": "chunked-file",
                    "path_b64": path_b64,
                    "mode": mode,
                    "chunks": chunk_ids,
                }
            )

    manifest = {
        "format_version": MANIFEST_VERSION,
        "codec": CODEC,
        "entries": manifest_entries,
    }
    manifest_bytes = json.dumps(
        manifest, ensure_ascii=True, separators=(",", ":"), sort_keys=True
    ).encode("utf-8")

    out = io.BytesIO()
    with tarfile.open(fileobj=out, mode="w") as tf:
        tf.addfile(_stable_tarinfo("manifest.json", 0o644, len(manifest_bytes)), io.BytesIO(manifest_bytes))
        for digest in sorted(blobs):
            blob = blobs[digest]
            tf.addfile(_stable_tarinfo(f"blobs/{digest}", 0o644, len(blob)), io.BytesIO(blob))
    return out.getvalue()


def _xz_compress(data: bytes) -> bytes:
    return lzma.compress(data, preset=(9 | lzma.PRESET_EXTREME))


def _write_wrapped_b64(f, value: str) -> None:
    f.write(f"PAYLOAD_B64 = {value!r}\n\n")


raw_paths = subprocess.check_output(
    [
        "git",
        "-c",
        "core.quotepath=off",
        "ls-files",
        "-z",
        "--cached",
        "--others",
        "--exclude-standard",
    ],
    cwd=repo_root,
)
paths = [p for p in raw_paths.decode("utf-8", "surrogateescape").split("\0") if p]
paths.sort(key=lambda p: p.encode("utf-8", "surrogateescape"))

entries = []
file_count = 0
link_count = 0

for rel_path in paths:
    if out_skip and rel_path == out_skip:
        continue

    full_path = repo_root / rel_path

    if full_path.is_symlink():
        entries.append({"kind": "symlink", "path": rel_path, "target": os.readlink(full_path)})
        link_count += 1
        continue

    if not full_path.is_file():
        continue

    mode = stat.S_IMODE(full_path.stat().st_mode)
    entries.append({"kind": "file", "path": rel_path, "mode": mode, "data": full_path.read_bytes()})
    file_count += 1

bundle_tar = _build_tar_bundle(entries)
chunkstore_tar = _build_chunkstore_bundle(entries)

bundle_payload = _xz_compress(bundle_tar)
chunkstore_payload = _xz_compress(chunkstore_tar)

if len(chunkstore_payload) < len(bundle_payload):
    payload_kind = "chunkstore-tar-v1"
    payload = chunkstore_payload
else:
    payload_kind = "bundle-tar-v1"
    payload = bundle_payload

payload_b64 = base64.b64encode(payload).decode("ascii")

tmp_fd, tmp_name = tempfile.mkstemp(prefix=f"{out_abs.name}.", suffix=".tmp", dir=str(out_abs.parent))
os.close(tmp_fd)

header = """# GEN CODE SCRIPT
import base64
import hashlib
import io
import json
import lzma
import os
import shutil
import sys
import tarfile
from pathlib import Path


def _remove_if_exists(path: Path) -> None:
    if path.is_symlink() or path.is_file():
        path.unlink()
    elif path.is_dir():
        shutil.rmtree(path)


def _decode_text_b64(value: str) -> str:
    return base64.b64decode(value.encode("ascii")).decode("utf-8", "surrogateescape")


def _decode_payload() -> bytes:
    if CODEC.get("dictionary") is not None:
        raise ValueError("Unsupported payload dictionary in this restore script.")
    if CODEC.get("name") != "lzma/xz":
        raise ValueError(f"Unsupported payload codec: {CODEC.get('name')!r}")
    raw = base64.b64decode(PAYLOAD_B64.encode("ascii"))
    return lzma.decompress(raw)


def _restore_bundle(payload: bytes, target_dir: Path) -> int:
    restored = 0
    with tarfile.open(fileobj=io.BytesIO(payload), mode="r:") as tf:
        for member in tf:
            if member.isdir():
                continue
            rel_path = member.name
            dst = target_dir / rel_path
            dst.parent.mkdir(parents=True, exist_ok=True)
            _remove_if_exists(dst)

            if member.issym():
                os.symlink(member.linkname, dst)
                restored += 1
                continue

            if not member.isfile():
                continue

            src = tf.extractfile(member)
            if src is None:
                raise ValueError(f"Unable to extract payload member: {member.name}")
            dst.write_bytes(src.read())
            os.chmod(dst, member.mode)
            restored += 1
    return restored


def _restore_chunkstore(payload: bytes, target_dir: Path) -> int:
    with tarfile.open(fileobj=io.BytesIO(payload), mode="r:") as tf:
        members = {m.name: m for m in tf.getmembers()}
        manifest_member = members.get("manifest.json")
        if manifest_member is None:
            raise ValueError("chunkstore payload is missing manifest.json")
        manifest_raw = tf.extractfile(manifest_member)
        if manifest_raw is None:
            raise ValueError("Unable to read manifest.json from chunkstore payload")
        manifest = json.loads(manifest_raw.read().decode("utf-8"))
        if manifest.get("format_version") != 1:
            raise ValueError(
                f"Unsupported chunkstore manifest version: {manifest.get('format_version')!r}"
            )
        manifest_codec = manifest.get("codec", {})
        if manifest_codec.get("name") != CODEC.get("name"):
            raise ValueError("Payload codec metadata mismatch.")

        blobs = {}
        for name, member in members.items():
            if not name.startswith("blobs/") or not member.isfile():
                continue
            digest = name.split("/", 1)[1]
            raw_blob = tf.extractfile(member)
            if raw_blob is None:
                raise ValueError(f"Unable to read blob payload: {name}")
            blob = raw_blob.read()
            if hashlib.sha256(blob).hexdigest() != digest:
                raise ValueError(f"Blob digest mismatch for {digest}")
            blobs[digest] = blob

    restored = 0
    for entry in manifest.get("entries", []):
        kind = entry.get("kind")
        rel_path = _decode_text_b64(entry["path_b64"])
        dst = target_dir / rel_path
        dst.parent.mkdir(parents=True, exist_ok=True)
        _remove_if_exists(dst)

        if kind == "symlink":
            os.symlink(_decode_text_b64(entry["target_b64"]), dst)
            restored += 1
            continue

        mode = entry["mode"]
        if kind == "file":
            digest = entry["blob"]
            blob = blobs.get(digest)
            if blob is None:
                raise ValueError(f"Missing blob: {digest}")
            dst.write_bytes(blob)
            os.chmod(dst, mode)
            restored += 1
            continue

        if kind == "chunked-file":
            with open(dst, "wb") as out_f:
                for digest in entry.get("chunks", []):
                    blob = blobs.get(digest)
                    if blob is None:
                        raise ValueError(f"Missing chunk blob: {digest}")
                    out_f.write(blob)
            os.chmod(dst, mode)
            restored += 1
            continue

        raise ValueError(f"Unknown chunkstore entry kind: {kind!r}")
    return restored


def restore(target_dir: Path) -> int:
    if FORMAT_VERSION != 2:
        raise ValueError(f"Unsupported snapshot format version: {FORMAT_VERSION!r}")
    target_dir.mkdir(parents=True, exist_ok=True)
    payload = _decode_payload()
    if PAYLOAD_KIND == "bundle-tar-v1":
        return _restore_bundle(payload, target_dir)
    if PAYLOAD_KIND == "chunkstore-tar-v1":
        return _restore_chunkstore(payload, target_dir)
    raise ValueError(f"Unsupported payload kind: {PAYLOAD_KIND!r}")


def gen_full() -> None:
    out = (Path.cwd() / DEFAULT_RESTORE_DIR).resolve()
    # In notebooks, IPython injects argv like: -f /path/to/kernel.json.
    # We ignore flag-looking args and only accept a direct positional path.
    if len(sys.argv) > 1:
        first = sys.argv[1]
        if not first.startswith("-"):
            out = Path(first).resolve()
    restored = restore(out)
    print(f"Restored {restored} entries into: {out}")
"""

with open(tmp_name, "w", encoding="utf-8", newline="\n") as f:
    f.write(header)
    f.write(f"FORMAT_VERSION = {FORMAT_VERSION}\n")
    f.write(f"DEFAULT_RESTORE_DIR = {repo_root.name!r}\n")
    f.write(f"PAYLOAD_KIND = {payload_kind!r}\n")
    f.write(f"CODEC = {CODEC!r}\n")
    f.write(f"ENTRY_COUNT = {file_count + link_count}\n\n")
    _write_wrapped_b64(f, payload_b64)
    f.write("gen_full()\n")

os.chmod(tmp_name, 0o755)
tmp_path = Path(tmp_name)
should_overwrite = True

if out_abs.exists() and out_abs.is_file():
    should_overwrite = out_abs.read_bytes() != tmp_path.read_bytes()

if should_overwrite:
    os.replace(tmp_name, out_abs)
    print(f"Snapshot script updated: {out_abs}")
else:
    tmp_path.unlink()
    print(f"Snapshot script unchanged: {out_abs}")

print(f"Snapshot entries: files={file_count}, symlinks={link_count}")
print(
    "Snapshot payload: "
    f"kind={payload_kind}, "
    f"bundle_xz_bytes={len(bundle_payload)}, "
    f"chunkstore_xz_bytes={len(chunkstore_payload)}, "
    f"selected_base64_bytes={len(payload_b64)}"
)
if out_skip:
    print(f"Snapshot excluded output path: {out_skip}")
PY
fi

if [[ "${#SELECTED_ARTIFACTS[@]}" -gt 0 ]]; then
  mkdir -p "$UPLOAD_ROOT_ABS"
  echo "Initialized Kaggle upload folders:"
  echo "  upload root: $UPLOAD_ROOT_ABS"

  # Clean legacy monolithic upload layout from older script versions.
  LEGACY_DATASET_DIR="$UPLOAD_ROOT_ABS/$REPO_SLUG"
  if [[ -d "$LEGACY_DATASET_DIR" ]]; then
    echo "  removed legacy folder: $LEGACY_DATASET_DIR"
    rm -rf "$LEGACY_DATASET_DIR"
  fi

  for artifact in "${SELECTED_ARTIFACTS[@]}"; do
    artifact_id="$(slugify "$artifact")"
    artifact_slug="${REPO_SLUG}-${artifact_id}"
    artifact_dir="$UPLOAD_ROOT_ABS/$artifact_slug"
    metadata_path="$artifact_dir/dataset-metadata.json"
    dataset_id="${KAGGLE_USERNAME}/${artifact_slug}"
    mkdir -p "$artifact_dir"
    echo "  artifact: $artifact"
    echo "    artifact id: $artifact_id"
    echo "    dataset id: $dataset_id"
    echo "    dataset dir: $artifact_dir"

    # Clean stale generated entries while keeping metadata file path stable.
    find "$artifact_dir" -mindepth 1 -maxdepth 1 ! -name 'dataset-metadata.json' -exec rm -rf {} +
    artifact_source=""
    artifact_item_name=""

    if [[ "$artifact" != "wheelhouse" ]]; then
      if [[ "$artifact" == /* ]]; then
        src="$artifact"
      else
        src="$REPO_ROOT/$artifact"
      fi
      artifact_source="$artifact"
      artifact_item_name="$(basename "$artifact")"
      if [[ -z "$artifact_item_name" ]] || [[ "$artifact_item_name" == "." ]] || [[ "$artifact_item_name" == "/" ]]; then
        artifact_item_name="$artifact_id"
      fi
      dst="$artifact_dir/$artifact_item_name"
      if [[ ! -e "$src" ]]; then
        echo "    link: skipped (missing source: $src)" >&2
        rm -f "$dst"
      else
        ln -sfn "$src" "$dst"
        echo "    link: $dst -> $src"
      fi
    else
      artifact_item_name="wheelhouse.zip"
      build_wheelhouse_for_init
    fi

    "$PYTHON_BIN" - "$metadata_path" "$REPO_NAME" "$KAGGLE_USERNAME" "$artifact_slug" "$artifact" "$artifact_id" "$artifact_source" "$artifact_item_name" <<'PY'
import json
import sys
from pathlib import Path

metadata_path = Path(sys.argv[1])
repo_name = sys.argv[2]
kaggle_username = sys.argv[3]
dataset_slug = sys.argv[4]
artifact = sys.argv[5]
artifact_id = sys.argv[6]
artifact_source = sys.argv[7]
artifact_item_name = sys.argv[8]

metadata = {
    "title": f"{repo_name} {artifact}",
    "id": f"{kaggle_username}/{dataset_slug}",
    "licenses": [{"name": "other"}],
    "description": (
        f"Artifact dataset for '{repo_name}': {artifact}. "
        "Managed by syk4y init/upload."
    ),
    "syk4y_artifact": artifact,
    "syk4y_artifact_id": artifact_id,
    "syk4y_source": artifact_source,
    "syk4y_item_name": artifact_item_name,
}

metadata_path.write_text(json.dumps(metadata, indent=2) + "\n", encoding="utf-8")
PY
    echo "    metadata: $metadata_path"
  done
fi

if [[ "$SKIP_GEN" -eq 0 ]]; then
  echo "  snapshot script: $OUT_ABS"
fi
echo "Done."
