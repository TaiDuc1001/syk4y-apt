#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  syk4y upload [--repo-root DIR] [options]

Options:
  -u, --upload-dir DIR   Upload root (default: kaggle_upload under repo root)
  --force                Force upload even if no changes detected
  -m, --message TEXT     Kaggle version message override
  --dir-mode MODE        Kaggle dir mode: skip|zip|tar
  -h, --help             Show this help
USAGE
}

repo_root="$(pwd)"
if [[ $# -gt 0 ]] && [[ "$1" == "--repo-root" ]]; then
  if [[ $# -lt 2 ]]; then
    echo "Missing value for --repo-root" >&2
    exit 2
  fi
  repo_root="$2"
  shift 2
fi

upload_root=""
force=0
message=""
dir_mode=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -u|--upload-dir)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      upload_root="$2"
      shift 2
      ;;
    --force)
      force=1
      shift
      ;;
    -m|--message)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      message="$2"
      shift 2
      ;;
    --dir-mode)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for $1" >&2
        exit 2
      fi
      dir_mode="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown upload option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

env_args=()
if [[ -n "$upload_root" ]]; then
  env_args+=(KAGGLE_UPLOAD_ROOT="$upload_root")
fi
if [[ "$force" -eq 1 ]]; then
  env_args+=(KAGGLE_FORCE_UPLOAD=1)
fi
if [[ -n "$message" ]]; then
  env_args+=(KAGGLE_VERSION_MESSAGE="$message")
fi
if [[ -n "$dir_mode" ]]; then
  env_args+=(KAGGLE_DIR_MODE="$dir_mode")
fi

exec env "${env_args[@]}" "$SCRIPT_DIR/syk4y-upload-artifacts" --repo-root "$repo_root"
